                  <div className="pt-2">
                    <h3 className="text-base font-medium text-neutral-900 dark:text-neutral-100 mb-2">{l.title}</h3>
                    <p className="text-sm text-neutral-500 dark:text-neutral-400 leading-relaxed">{l.body}</p>
